# === Supabase ===
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === LLM ===
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === Email ===
RESEND_API_KEY=your-resend-key

# === Monitoring ===
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
SENTRY_DSN=https://your-key@o0.ingest.sentry.io/0
HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid

# === Admin ===
ADMIN_TOKEN=replace-with-32-byte-random-token

# === Behavior ===
CRAWL_MAX_QPS_PER_DOMAIN=1.0
LOG_LEVEL=INFO

# === Local Dev (使用 docker-compose 的本地 Postgres 时) ===
# 把 SUPABASE_URL 改成本地连接字符串需要 supabase-py 不直接支持，
# 本地开发推荐直接连 Supabase 项目（有免费 staging 项目）。
